<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luca — Booked.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Helvetica+Neue:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --gold:                #C8A96E;
    --gold-light:          #e2c98a;
    --void:                #0e0a1a;
    --off-white:           #f0ede8;
    --subtext:             #9a9a9a;
    --violet-italic:       #a98fe0;
    --gold-border-default: rgba(200,169,110,0.12);
    --gold-border-hover:   rgba(200,169,110,0.35);
    --gold-border-divider: rgba(200,169,110,0.10);
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body:    'Helvetica Neue', Helvetica, sans-serif;
    --bg:           var(--void);
    --bg-card:      #0e1020;
    --gold-border:  var(--gold-border-default);
    --gold-dim:     rgba(200,169,110,0.15);
    --text:         var(--off-white);
    --muted:        var(--subtext);
    --dim:          #444;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

  body {
    background: var(--void);
    color: var(--off-white);
    font-family: var(--font-body);
    font-weight: 200;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse at 60% 40%, rgba(120,80,200,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 20% 80%, rgba(80,40,160,0.08) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 48px;
    border-bottom: 1px solid var(--gold-border-divider);
    background: rgba(10,14,26,0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--text);
    text-decoration: none;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
  }

  .nav-links a {
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active { color: var(--gold); }

  .nav-contact {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border: 1px solid var(--gold-border);
    color: var(--gold) !important;
    font-size: 10px !important;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s;
    font-family: var(--font-body);
    white-space: nowrap;
  }

  .nav-contact:hover {
    background: var(--gold-dim);
    color: var(--gold-light) !important;
  }

  /* ── HERO: desktop split ── */
  .hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 140px 56px 80px 48px;
  }

  .section-tag {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 12px;
    animation: fadeUp 0.6s 0.0s ease both;
  }

  .section-tag::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
    flex-shrink: 0;
  }

  .hero-left h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 64px);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin-bottom: 28px;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .hero-left h1 em {
    font-style: italic;
    color: var(--violet-italic);
  }

  .hero-sub {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.85;
    max-width: 400px;
    margin-bottom: 40px;
    font-weight: 300;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  .hero-sub strong {
    color: var(--text);
    font-weight: 400;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--gold);
    color: var(--bg);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: var(--font-body);
    transition: background 0.2s;
    width: fit-content;
    -webkit-tap-highlight-color: transparent;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .btn-primary:hover,
  .btn-primary:active { background: var(--gold-light); }

  /* photo panel */
  .hero-right {
    position: relative;
    overflow: hidden;
  }

  .hero-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: brightness(0.88) contrast(1.04);
  }

  .hero-right::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(14,10,26,0.4) 0%, transparent 25%);
    pointer-events: none;
  }

  /* ── PAGE SECTIONS ── */
  .page {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 100px 48px 120px;
  }

  /* market strip */
  .market-strip {
    display: flex;
    flex-wrap: wrap;
    border: 1px solid var(--gold-border-default);
    margin-bottom: 100px;
    overflow: hidden;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .market-item {
    flex: 1;
    min-width: 110px;
    padding: 28px 20px;
    border-right: 1px solid var(--gold-border-default);
    text-align: center;
  }

  .market-item:last-child { border-right: none; }

  .market-city {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
    color: var(--text);
    display: block;
    margin-bottom: 4px;
  }

  .market-region {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* what grid */
  .what-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 72px;
    margin-bottom: 100px;
    align-items: start;
    animation: fadeUp 0.6s 0.15s ease both;
  }

  .what-label {
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 300;
    line-height: 1.1;
    color: var(--text);
    position: sticky;
    top: 100px;
  }

  .what-label em {
    font-style: italic;
    color: var(--violet-italic);
  }

  .what-items { display: flex; flex-direction: column; }

  .what-item {
    padding: 32px 0;
    border-bottom: 1px solid var(--gold-border-divider);
  }

  .what-item:first-child { border-top: 1px solid var(--gold-border-divider); }

  .what-item-num {
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--gold);
    margin-bottom: 10px;
    display: block;
  }

  .what-item h3 {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 400;
    margin-bottom: 10px;
    color: var(--text);
  }

  .what-item p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.75;
    font-weight: 300;
  }

  /* contact block */
  .contact-block {
    background: var(--bg-card);
    border: 1px solid var(--gold-border-default);
    padding: 56px 52px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: center;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  .contact-block h2 {
    font-family: var(--font-display);
    font-size: clamp(26px, 2.8vw, 42px);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 14px;
  }

  .contact-block h2 em {
    font-style: italic;
    color: var(--violet-italic);
  }

  .contact-block p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
    font-weight: 300;
    max-width: 400px;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--gold);
    color: var(--bg);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: var(--font-body);
    transition: background 0.2s;
    white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-cta:hover,
  .btn-cta:active { background: var(--gold-light); }

  footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--gold-border);
    padding: 40px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .footer-note {
    font-size: 11px;
    color: var(--subtext);
    letter-spacing: 0.05em;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ════════════════════════════════════
     RESPONSIVE BREAKPOINTS
     ════════════════════════════════════ */

  /* Large desktop */
  @media (min-width: 1440px) {
    .hero-left { padding: 140px 72px 80px 80px; }
    .page { max-width: 1400px; padding: 100px 80px 140px; }
    footer { max-width: 1400px; padding: 40px 80px; }
  }

  /* Tablet landscape */
  @media (max-width: 1100px) {
    nav { padding: 20px 32px; }
    .hero-left { padding: 130px 40px 72px 32px; }
    .page { padding: 80px 32px 100px; }
    .what-grid { grid-template-columns: 220px 1fr; gap: 48px; }
    footer { padding: 36px 32px; }
  }

  /* Tablet portrait — stack hero */
  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    /* Photo moves to top on tablet/mobile */
    .hero-right {
      order: -1;
      height: 75vw;
      max-height: 520px;
    }

    .hero-right img {
      object-position: center 12%;
    }

    .hero-right::after {
      background: linear-gradient(to bottom, transparent 55%, rgba(14,10,26,0.85) 100%);
    }

    .hero-left {
      padding: 48px 32px 72px;
    }

    .hero-left h1 {
      font-size: clamp(34px, 6vw, 52px);
    }

    .hero-sub { max-width: 100%; }

    .page { padding: 72px 32px 80px; }

    .what-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .what-label {
      position: static;
      font-size: 30px;
    }

    .contact-block {
      grid-template-columns: 1fr;
      padding: 44px 36px;
      gap: 28px;
    }

    footer { padding: 32px; }
  }

  /* Mobile */
  @media (max-width: 640px) {
    nav { padding: 18px 20px; }
    .nav-links { display: none; }

    .hero-right {
      height: 85vw;
      max-height: 460px;
    }

    .hero-right img {
      object-position: center 10%;
    }

    .hero-left { padding: 40px 20px 60px; }

    .hero-left h1 { font-size: clamp(32px, 8vw, 46px); }

    .section-tag { font-size: 9px; margin-bottom: 24px; }

    .hero-sub { font-size: 14px; margin-bottom: 32px; }

    .btn-primary {
      width: 100%;
      justify-content: center;
      padding: 16px 24px;
    }

    .page { padding: 56px 20px 72px; }

    /* market strip: horizontal scroll on mobile */
    .market-strip {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin-bottom: 64px;
      scrollbar-width: none;
    }

    .market-strip::-webkit-scrollbar { display: none; }

    .market-item {
      flex: 0 0 auto;
      min-width: 140px;
      border-right: 1px solid var(--gold-border-default);
      border-bottom: none;
      padding: 24px 20px;
    }

    .market-item:last-child { border-right: none; }

    .market-city { font-size: 16px; }

    .what-grid { gap: 28px; margin-bottom: 64px; }
    .what-label { font-size: 28px; }
    .what-item { padding: 24px 0; }
    .what-item h3 { font-size: 19px; }

    .contact-block { padding: 36px 20px; }
    .contact-block h2 { font-size: 26px; }

    .btn-cta {
      width: 100%;
      justify-content: center;
      padding: 16px 24px;
    }

    footer {
      padding: 28px 20px;
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }

  /* Small mobile (iPhone SE etc) */
  @media (max-width: 390px) {
    nav { padding: 16px; }
    .nav-logo { font-size: 15px; }
    .nav-contact { display: none; }

    .hero-right { height: 90vw; max-height: 380px; }
    .hero-right img { object-position: center 8%; }
    .hero-left { padding: 32px 16px 52px; }
    .hero-left h1 { font-size: 30px; }
    .hero-sub { font-size: 13px; }

    .page { padding: 48px 16px 60px; }
    .market-city { font-size: 14px; }
    .market-region { font-size: 8px; }

    footer { padding: 24px 16px; }
    .footer-note { font-size: 10px; }
  }
</style>
</head>
<body>

